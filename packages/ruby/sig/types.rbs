    attr_accessor country: String?

    def initialize: (model: String, query: String, ?max_results: Integer, ?search_domain_filter: Array[String], ?country: String) -> void
  end

  class SearchResponse
    # A search response.

    # List of search results.
    attr_reader results: Array[SearchResult]
    # Model/provider that performed the search.
    attr_reader model: String

    def initialize: (results: Array[SearchResult], model: String) -> void
  end

  class SearchResult
    # An individual search result.

    # Result title.
    attr_reader title: String
    # Result URL.
    attr_reader url: String
    # Text snippet or excerpt from the page.
    attr_reader snippet: String
    # Publication or last-updated date, if available.
    attr_reader date: String

    def initialize: (title: String, url: String, snippet: String, ?date: String) -> void
  end

  class OcrRequest
    # An OCR request.

    # The model/provider to use (e.g. `"mistral/mistral-ocr-latest"`).
    attr_accessor model: String?
    # The document to process (URL or base64).
    attr_accessor document: OcrDocument?
    # Specific pages to process (1-indexed). `None` means all pages.
    attr_accessor pages: Array[Integer]?
    # Whether to include base64-encoded images of each processed page.
    attr_accessor include_image_base64: bool?

    def initialize: (model: String, document: OcrDocument, ?pages: Array[Integer], ?include_image_base64: bool) -> void
  end

  class OcrResponse
    # An OCR response.

    # Extracted pages in order.
    attr_reader pages: Array[OcrPage]
    # Model/provider used for OCR.
    attr_reader model: String
    # Token usage, if reported by the provider.
    attr_reader usage: Usage

    def initialize: (pages: Array[OcrPage], model: String, ?usage: Usage) -> void
  end

  class OcrPage
    # A single page of OCR output.

    # Page index (0-based).
    attr_reader index: Integer
    # Extracted page content as Markdown.
    attr_reader markdown: String
    # Embedded images extracted from the page (if `include_image_base64` was true).
    attr_reader images: Array[OcrImage]
    # Page dimensions in pixels, if available.
    attr_reader dimensions: PageDimensions

    def initialize: (index: Integer, markdown: String, ?images: Array[OcrImage], ?dimensions: PageDimensions) -> void
  end

  class OcrImage
    # An image extracted from an OCR page.

    # Unique image identifier within the document.
    attr_reader id: String
    # Base64-encoded image data (if `include_image_base64` was true).
    attr_reader image_base64: String

    def initialize: (id: String, ?image_base64: String) -> void
  end

  class PageDimensions
    # Page dimensions in pixels.

    # Width in pixels.
    attr_reader width: Integer
    # Height in pixels.
    attr_reader height: Integer

    def initialize: (width: Integer, height: Integer) -> void
  end

  class ModelsListResponse
    # Response listing available models.

    # Always `"list"` from OpenAI-compatible APIs.  Stored as a plain
    # `String` so non-standard provider values do not break deserialization.
    attr_accessor object: String?
    # List of available models.
    attr_accessor data: Array[ModelObject]?

    def initialize: (object: String, data: Array[ModelObject]) -> void
  end

  class ModelObject
    # A model available from the API.

    # Model ID (e.g., `"gpt-4o"`, `"claude-3-5-sonnet"`).
    attr_accessor id: String?
    # Always `"model"` from OpenAI-compatible APIs.  Stored as a plain
    # `String` so non-standard provider values do not break deserialization.
    attr_accessor object: String?
    # Unix timestamp of model creation (or release date).
    attr_accessor created: Integer?
    # Organization or entity that owns the model.
    attr_accessor owned_by: String?

    def initialize: (id: String, object: String, created: Integer, owned_by: String) -> void
  end

  class CreateFileRequest
    # Request to upload a file.

    # Base64-encoded file data.
    attr_accessor file: String?
    # Purpose for the file.
    attr_accessor purpose: FilePurpose?
    # Optional filename to associate with the upload.
    attr_accessor filename: String?

    def initialize: (file: String, purpose: FilePurpose, ?filename: String) -> void
  end

  class FileObject
    # An uploaded file object.

    # Unique file ID.
    attr_accessor id: String?
    # Object type (always `"file"`).
    attr_accessor object: String?
    # File size in bytes.
    attr_accessor bytes: Integer?
    # Unix timestamp of file creation.
    attr_accessor created_at: Integer?
    # Filename.
    attr_accessor filename: String?
    # File purpose.
    attr_accessor purpose: String?
    # Processing status (e.g., `"uploaded"`, `"processed"`).
    attr_accessor status: String?

    def initialize: (id: String, object: String, bytes: Integer, created_at: Integer, filename: String, purpose: String, ?status: String) -> void
  end

  class FileListResponse
    # Response from listing files.

    # Object type (always `"list"`).
    attr_accessor object: String?
    # List of file objects.
    attr_accessor data: Array[FileObject]?
    # Whether more results are available.
    attr_accessor has_more: bool?

    def initialize: (object: String, data: Array[FileObject], ?has_more: bool) -> void
  end

  class FileListQuery
    # Query parameters for listing files.

    # Filter by file purpose (e.g., `"batch"`, `"fine-tune"`).
    attr_accessor purpose: String?
    # Maximum number of results to return. Defaults to 20.
    attr_accessor limit: Integer?
    # Pagination cursor: return results after this file ID.
    attr_accessor after: String?

    def initialize: (?purpose: String, ?limit: Integer, ?after: String) -> void
  end

  class DeleteResponse
    # Response from a delete operation.

    # ID of the deleted resource.
    attr_accessor id: String?
    # Object type.
    attr_accessor object: String?
    # Confirmation that the resource was deleted.
    attr_accessor deleted: bool?

    def initialize: (id: String, object: String, deleted: bool) -> void
  end

  class CreateBatchRequest
    # Request to create a batch job.

    # ID of the uploaded input file (JSONL format).
    attr_accessor input_file_id: String?
    # API endpoint (e.g., `"/v1/chat/completions"`).
    attr_accessor endpoint: String?
    # Completion window (e.g., `"24h"`).
    attr_accessor completion_window: String?
    # Optional metadata to attach to the batch.
    attr_accessor metadata: untyped?

    def initialize: (input_file_id: String, endpoint: String, completion_window: String, ?metadata: untyped) -> void
  end

  class BatchObject
    # A batch job object.

    # Unique batch ID.
    attr_accessor id: String?
    # Object type (always `"batch"`).
    attr_accessor object: String?
    # API endpoint (e.g., `"/v1/chat/completions"`).
    attr_accessor endpoint: String?
    # ID of the input file.
    attr_accessor input_file_id: String?
    # Completion window (e.g., `"24h"`).
    attr_accessor completion_window: String?
    # Current job status.
    attr_accessor status: BatchStatus?
    # ID of the output file (present when completed).
    attr_accessor output_file_id: String?
    # ID of the error file (present if some requests failed).
    attr_accessor error_file_id: String?
    # Unix timestamp of batch creation.
    attr_accessor created_at: Integer?
    # Unix timestamp of completion (if completed).
    attr_accessor completed_at: Integer?
    # Unix timestamp of failure (if failed).
    attr_accessor failed_at: Integer?
    # Unix timestamp of expiration (if expired).
    attr_accessor expired_at: Integer?
    # Request processing counts.
    attr_accessor request_counts: BatchRequestCounts?
    # Metadata attached to the batch.
    attr_accessor metadata: untyped?

    def initialize: (id: String, object: String, endpoint: String, input_file_id: String, completion_window: String, status: BatchStatus, ?output_file_id: String, ?error_file_id: String, created_at: Integer, ?completed_at: Integer, ?failed_at: Integer, ?expired_at: Integer, ?request_counts: BatchRequestCounts, ?metadata: untyped) -> void
  end

  class BatchRequestCounts
    # Request processing counts for a batch.

    # Total requests in the batch.
    attr_accessor total: Integer?
    # Completed requests.
    attr_accessor completed: Integer?
    # Failed requests.
    attr_accessor failed: Integer?

    def initialize: (total: Integer, completed: Integer, failed: Integer) -> void
  end

  class BatchListResponse
    # Response from listing batches.

    # Object type (always `"list"`).
    attr_accessor object: String?
    # List of batch objects.
    attr_accessor data: Array[BatchObject]?
    # Whether more results are available.
    attr_accessor has_more: bool?
    # First batch ID in the result set (for pagination).
    attr_accessor first_id: String?
    # Last batch ID in the result set (for pagination).
    attr_accessor last_id: String?

    def initialize: (object: String, data: Array[BatchObject], ?has_more: bool, ?first_id: String, ?last_id: String) -> void
  end

  class BatchListQuery
    # Query parameters for listing batches.

    # Maximum number of results to return. Defaults to 20.
    attr_accessor limit: Integer?
    # Pagination cursor: return results after this batch ID.
    attr_accessor after: String?

    def initialize: (?limit: Integer, ?after: String) -> void
  end

  class CreateResponseRequest
    # Request to create a structured response.

    # Model ID.
    attr_accessor model: String?
    # Input data to process (e.g., a document to extract from).
    attr_accessor input: untyped?
    # Instructions for processing the input.
    attr_accessor instructions: String?
    # Available tools the model can use.
    attr_accessor tools: Array[ResponseTool]?
    # Sampling temperature in `[0.0, 2.0]`. Defaults to 1.0.
    attr_accessor temperature: Float?
    # Maximum output tokens.
    attr_accessor max_output_tokens: Integer?
    # Optional metadata.
    attr_accessor metadata: untyped?

    def initialize: (model: String, input: untyped, ?instructions: String, ?tools: Array[ResponseTool], ?temperature: Float, ?max_output_tokens: Integer, ?metadata: untyped) -> void
  end

  class ResponseTool
    # A tool available for the response request.

    # Tool type (e.g., "extractor", "search").
    attr_accessor tool_type: String?
    # Tool configuration (flattened into the object).
    attr_accessor config: untyped?

    def initialize: (tool_type: String, config: untyped) -> void
  end

  class ResponseObject
    # Response from a structured response request.

    # Unique response ID.
    attr_accessor id: String?
    # Object type (e.g., `"response"`).
    attr_accessor object: String?
    # Unix timestamp of response creation.
    attr_accessor created_at: Integer?
    # Model used to generate the response.
    attr_accessor model: String?
    # Status (e.g., `"succeeded"`, `"failed"`).
    attr_accessor status: String?
    # Output items from the response.
    attr_accessor output: Array[ResponseOutputItem]?
    # Token usage.
    attr_accessor usage: ResponseUsage?
    # Error details (if status is "failed").
    attr_accessor error: untyped?

    def initialize: (id: String, object: String, created_at: Integer, model: String, status: String, output: Array[ResponseOutputItem], ?usage: ResponseUsage, ?error: untyped) -> void
  end

  class ResponseOutputItem
    # A single output item from the response.

    # Output type (e.g., `"text"`, `"object"`, `"error"`).
    attr_accessor item_type: String?
    # Output content (flattened into the object).
    attr_accessor content: untyped?

    def initialize: (item_type: String, content: untyped) -> void
  end

  class ResponseUsage
    # Token usage for a response.

    # Input tokens used.
    attr_accessor input_tokens: Integer?
    # Output tokens used.
    attr_accessor output_tokens: Integer?
    # Total tokens used.
    attr_accessor total_tokens: Integer?

    def initialize: (input_tokens: Integer, output_tokens: Integer, total_tokens: Integer) -> void
  end

  class DefaultClient
    # Default client implementation backed by `reqwest`.
    #
    # Sends requests to 140+ LLM providers with automatic provider detection
    # and per-request routing. The provider is resolved at construction time
    # from `model_hint` (or defaults to OpenAI), but individual requests can
    # override the provider via model name prefix (e.g. `"anthropic/claude-3-5-sonnet"`
    # routes to Anthropic regardless of construction-time setting).
    #
    # When the model prefix does not match any known provider, the construction-time
    # provider is used as the fallback. This enables seamless migration between
    # providers by changing only the model name.
    #
    # The provider is stored behind an [`Arc`] so it can be shared cheaply into
    # async closures and streaming tasks. Pre-computed auth headers and extra
    # headers are cached at construction to avoid redundant encoding on every request.

    def chat: (ChatCompletionRequest req) -> ChatCompletionResponse
    def chat_stream: (ChatCompletionRequest req) -> String
    def embed: (EmbeddingRequest req) -> EmbeddingResponse
    def list_models: () -> ModelsListResponse
    def image_generate: (CreateImageRequest req) -> ImagesResponse
    def speech: (CreateSpeechRequest req) -> String
    def transcribe: (CreateTranscriptionRequest req) -> TranscriptionResponse
    def moderate: (ModerationRequest req) -> ModerationResponse
    def rerank: (RerankRequest req) -> RerankResponse
    def search: (SearchRequest req) -> SearchResponse
    def ocr: (OcrRequest req) -> OcrResponse
    def create_file: (CreateFileRequest req) -> FileObject
    def retrieve_file: (String file_id) -> FileObject
    def delete_file: (String file_id) -> DeleteResponse
    def list_files: (?FileListQuery query) -> FileListResponse
    def file_content: (String file_id) -> String
    def create_batch: (CreateBatchRequest req) -> BatchObject
    def retrieve_batch: (String batch_id) -> BatchObject
    def list_batches: (?BatchListQuery query) -> BatchListResponse
    def cancel_batch: (String batch_id) -> BatchObject
    def create_response: (CreateResponseRequest req) -> ResponseObject
    def retrieve_response: (String id) -> ResponseObject
    def cancel_response: (String id) -> ResponseObject
  end

  class CustomProviderConfig
    # Configuration for registering a custom LLM provider at runtime.

    # Unique name for this provider (e.g., "my-provider").
    attr_reader name: String
    # Base URL for the provider's API (e.g., "https://api.my-provider.com/v1").
    attr_reader base_url: String
    # Authentication header format.
    attr_reader auth_header: AuthHeaderFormat
    # Model name prefixes that route to this provider (e.g., ["my-"]).
    attr_reader model_prefixes: Array[String]

    def initialize: (name: String, base_url: String, auth_header: AuthHeaderFormat, model_prefixes: Array[String]) -> void
  end

  class BudgetConfig
    # Configuration for budget enforcement.

    # Maximum total spend across all models, in USD.  `None` means unlimited.
    attr_accessor global_limit: Float?
    # Per-model spending limits in USD.  Models not listed here are only
    # constrained by `global_limit`.
    attr_accessor model_limits: Hash[String, Float]?
    # Whether to reject requests or merely warn when a limit is exceeded.
    attr_accessor enforcement: Enforcement?

    def initialize: (?global_limit: Float, model_limits: Hash[String, Float], enforcement: Enforcement) -> void
    def self.default: () -> BudgetConfig
  end

  class CacheConfig
    # Configuration for the response cache.

    # Maximum number of cached entries.
    attr_accessor max_entries: Integer?
    # Time-to-live for each cached entry.
    attr_accessor ttl: Integer?
    # Storage backend to use.
    attr_accessor backend: CacheBackend?

    def initialize: (max_entries: Integer, ttl: Integer, backend: CacheBackend) -> void
    def self.default: () -> CacheConfig
  end

  class RateLimitConfig
    # Configuration for per-model rate limits.

    # Maximum requests per window.  `None` means unlimited.
    attr_accessor rpm: Integer?
    # Maximum tokens per window.  `None` means unlimited.
    attr_accessor tpm: Integer?
    # Fixed window duration (defaults to 60 s).
    attr_accessor window: Integer?

    def initialize: (?rpm: Integer, ?tpm: Integer, window: Integer) -> void
    def self.default: () -> RateLimitConfig
  end

  class Message
    # A chat message in a conversation.
  end

  class UserContent
    # User message content as either plain text or a list of multimodal parts.
  end

  class ContentPart
    # A single content part in a user message — text, image, document, or audio.
  end

  class ImageDetail
    # Image detail level controlling token cost and processing.
    type value = :low | :high | :auto
  end

  class ToolType
    # The type discriminator for tool/tool-call objects.
    #
    # Per the OpenAI spec this is always `"function"`. Using an enum enforces
    # that constraint at the type level and rejects any other value on
    # deserialization.
    type value = :function
  end

  class ToolChoice
    # Tool usage mode or a specific tool to call.
  end

  class ToolChoiceMode
    # Tool choice mode.
    type value = :auto | :required | :none
  end

  class ResponseFormat
    # Response format constraint.
  end

  class StopSequence
    # Stop sequence(s) that cause the model to stop generating.
  end

  class FinishReason
    # Why a choice stopped generating tokens.
    type value = :stop | :length | :tool_calls | :content_filter | :function_call | :other
  end

  class ReasoningEffort
    # Controls how much reasoning effort the model should use.
    type value = :low | :medium | :high
  end

  class EmbeddingFormat
    # The format in which the embedding vectors are returned.
    type value = :float | :base64
  end

  class EmbeddingInput
    # Text or texts to embed.
  end

  class ModerationInput
    # Input to the moderation endpoint — a single string or multiple strings.
  end

  class RerankDocument
    # A document to be reranked — either a plain string or an object with a text field.
  end

  class OcrDocument
    # Document input for OCR — either a URL or inline base64 data.
  end

  class FilePurpose
    # Purpose of an uploaded file.
    type value = :assistants | :batch | :fine_tune | :vision
  end

  class BatchStatus
    # Status of a batch job.
    type value = :validating | :failed | :in_progress | :finalizing | :completed | :expired | :cancelling | :cancelled
  end

  class AuthHeaderFormat
    # How the API key is sent in the HTTP request.
  end

  class Enforcement
    # How budget limits are enforced.
    type value = :hard | :soft
  end

  class CacheBackend
    # Storage backend for the response cache.
  end

  def self.create_client: (String api_key, ?String base_url, ?Integer timeout_secs, ?Integer max_retries, ?String model_hint) -> DefaultClient

  def self.create_client_from_json: (String json) -> DefaultClient

end

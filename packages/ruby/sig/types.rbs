    def speech: (CreateSpeechRequest req) -> String
    def transcribe: (CreateTranscriptionRequest req) -> TranscriptionResponse
    def moderate: (ModerationRequest req) -> ModerationResponse
    def rerank: (RerankRequest req) -> RerankResponse
    def search: (SearchRequest req) -> SearchResponse
    def ocr: (OcrRequest req) -> OcrResponse
    def create_file: (CreateFileRequest req) -> FileObject
    def retrieve_file: (String file_id) -> FileObject
    def delete_file: (String file_id) -> DeleteResponse
    def list_files: (?FileListQuery query) -> FileListResponse
    def file_content: (String file_id) -> String
    def create_batch: (CreateBatchRequest req) -> BatchObject
    def retrieve_batch: (String batch_id) -> BatchObject
    def list_batches: (?BatchListQuery query) -> BatchListResponse
    def cancel_batch: (String batch_id) -> BatchObject
    def create_response: (CreateResponseRequest req) -> ResponseObject
    def retrieve_response: (String id) -> ResponseObject
    def cancel_response: (String id) -> ResponseObject

# frozen_string_literal: true

require "bundler"
Bundler::GemHelper.install_tasks name: "liter_llm"
require "rb_sys/extensiontask"
require "rspec/core/rake_task"

GEM_ROOT = __dir__
GEMSPEC = Gem::Specification.load(File.expand_path("liter_llm.gemspec", GEM_ROOT))

CROSS_PLATFORMS = %w[
  x86_64-linux
  aarch64-linux
  arm64-darwin
  x86_64-darwin
  x64-mingw-ucrt
].freeze

# rb_sys 0.9.x runs `cargo metadata` from the current working directory. When
# the gem lives inside a Cargo workspace that excludes this crate (monorepo
# layout), the metadata lookup resolves to the parent workspace and fails to
# locate the crate. Chdir into the manifest directory for the duration of the
# task construction so the metadata lookup finds the crate's own Cargo.toml.
MANIFEST_DIR = File.expand_path("ext/liter_llm_rb", GEM_ROOT)

Dir.chdir(MANIFEST_DIR) do
  RbSys::ExtensionTask.new("liter-llm-rb", GEMSPEC) do |ext|
    ext.lib_dir = "lib"
    ext.ext_dir = "ext/liter_llm_rb/native"
    ext.source_pattern = "*.{}"
    ext.platform = "ruby"
    ext.cross_compile = true
    ext.cross_platform = CROSS_PLATFORMS
  end
end

RSpec::Core::RakeTask.new(:spec)

task spec: :compile
task default: :spec

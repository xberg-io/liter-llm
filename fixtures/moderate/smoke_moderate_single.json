            "harassment": 0.0002,
            "self-harm": 0.0001,
            "sexual/minors": 0.0001,
            "hate/threatening": 0.0001,
            "violence/graphic": 0.0001,
            "self-harm/intent": 0.0001,
            "self-harm/instructions": 0.0001,
            "harassment/threatening": 0.0001,
            "violence": 0.0001
          }
        }

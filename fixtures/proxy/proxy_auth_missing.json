{
  "id": "proxy_auth_missing",
  "description": "401 Unauthorized when no API key is provided through the proxy",
  "category": "proxy",
  "tags": ["proxy", "error-handling"],
  "call": "chat",
  "input": {
    "model": "openai/gpt-4o",
    "messages": [
      {
        "role": "user",
        "content": "Hello"
      }
    ]
  },
  "mock_response": {
    "status": 401,
    "body": {
      "error": {
        "message": "You didn't provide an API key. You need to provide your API key in an Authorization header.",
        "type": "invalid_request_error",
        "param": null,
        "code": null
      }
    }
  },
  "assertions": [
    {
      "type": "error",
      "value": "Authentication"
    },
    {
      "type": "equals",
      "field": "error.status_code",
      "value": 401
    }
  ]
}

{
  "id": "proxy_image_generate",
  "description": "Image generation request routed through the proxy",
  "category": "proxy",
  "tags": ["proxy", "image"],
  "call": "image_generate",
  "input": {
    "model": "dall-e-3",
    "prompt": "A sunset over the ocean",
    "n": 1,
    "size": "1024x1024"
  },
  "mock_response": {
    "status": 200,
    "body": {
      "created": 1711000000,
      "data": [
        {
          "url": "https://example.com/images/img-proxy001.png",
          "revised_prompt": "A vivid sunset casting warm orange and pink hues over a calm ocean"
        }
      ]
    }
  },
  "assertions": [
    {
      "type": "not_error"
    },
    {
      "type": "count_equals",
      "field": "data",
      "value": 1
    },
    {
      "type": "not_empty",
      "field": "data[0].url"
    }
  ]
}

{
  "id": "proxy_rerank",
  "description": "Document reranking request routed through the proxy",
  "category": "proxy",
  "tags": ["proxy", "rerank"],
  "call": "rerank",
  "input": {
    "model": "rerank-v3.5",
    "query": "What is deep learning?",
    "documents": [
      "Deep learning is a subset of machine learning using neural networks.",
      "The stock market closed higher today."
    ]
  },
  "mock_response": {
    "status": 200,
    "body": {
      "id": "rerank-proxy001",
      "results": [
        {
          "index": 0,
          "relevance_score": 0.95
        },
        {
          "index": 1,
          "relevance_score": 0.03
        }
      ],
      "meta": {
        "api_version": {
          "version": "2"
        },
        "billed_units": {
          "search_units": 1
        }
      }
    }
  },
  "assertions": [
    {
      "type": "not_error"
    },
    {
      "type": "count_equals",
      "field": "results",
      "value": 2
    },
    {
      "type": "greater_than",
      "field": "results[0].relevance_score",
      "value": 0.9
    }
  ]
}

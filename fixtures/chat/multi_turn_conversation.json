{
  "id": "multi_turn_conversation",
  "description": "Multi-turn conversation with system, user, assistant, and follow-up user messages",
  "category": "chat",
  "tags": ["chat"],
  "call": "chat",
  "input": {
    "model": "gpt-4",
    "messages": [
      {
        "role": "system",
        "content": "You are a helpful assistant."
      },
      {
        "role": "user",
        "content": "What is 2 + 2?"
      },
      {
        "role": "assistant",
        "content": "2 + 2 equals 4."
      },
      {
        "role": "user",
        "content": "And what is 4 + 4?"
      }
    ]
  },
  "mock_response": {
    "status": 200,
    "body": {
      "id": "chatcmpl-multi001",
      "object": "chat.completion",
      "created": 1711000030,
      "model": "gpt-4",
      "choices": [
        {
          "index": 0,
          "message": {
            "role": "assistant",
            "content": "4 + 4 equals 8."
          },
          "finish_reason": "stop"
        }
      ],
      "usage": {
        "prompt_tokens": 45,
        "completion_tokens": 9,
        "total_tokens": 54
      }
    }
  },
  "assertions": [
    {
      "type": "not_error"
    },
    {
      "type": "count_equals",
      "field": "choices",
      "value": 1
    },
    {
      "type": "equals",
      "field": "choices[0].message.content",
      "value": "4 + 4 equals 8."
    },
    {
      "type": "equals",
      "field": "choices[0].finish_reason",
      "value": "stop"
    }
  ]
}

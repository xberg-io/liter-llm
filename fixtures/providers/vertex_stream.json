        "object": "chat.completion.chunk",
        "created": 1711000400,
        "model": "gemini-2.0-flash",
        "choices": [
          {
            "index": 0,
            "delta": {
              "content": "One"
            },
            "finish_reason": null
          }
        ]
      },
      {
        "id": "chatcmpl-vertex-stream001",
        "object": "chat.completion.chunk",
        "created": 1711000400,
        "model": "gemini-2.0-flash",
        "choices": [
          {
            "index": 0,

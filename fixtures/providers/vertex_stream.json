{
  "id": "vertex_stream",
  "description": "Streaming chat completion via the Google Vertex AI provider using the vertex_ai/ prefix — verifies SSE chunks from the Gemini streaming endpoint are yielded and assembled correctly",
  "category": "streaming",
  "tags": ["streaming", "vertex_ai"],
  "call": "chat_stream",
  "input": {
    "model": "vertex_ai/gemini-2.0-flash",
    "messages": [
      {
        "role": "user",
        "content": "Count to three, one word per response."
      }
    ],
    "stream": true,
    "max_tokens": 32
  },
  "mock_response": {
    "status": 200,
    "stream_chunks": [
      {

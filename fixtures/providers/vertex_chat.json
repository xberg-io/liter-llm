{
  "id": "vertex_chat",
  "description": "Basic chat completion via the Google Vertex AI provider using the vertex_ai/ prefix for routing — verifies the prefix is stripped before dispatching and the Gemini response is normalised to the standard OpenAI chat completion shape",
  "category": "smoke",
  "tags": ["smoke", "vertex_ai"],
  "call": "chat",
  "input": {
    "model": "vertex_ai/gemini-2.0-flash",
    "messages": [
      {
        "role": "user",
        "content": "Say hello in one word."
      }
    ],
    "temperature": 0,
    "max_tokens": 16
  },
  "mock_response": {
    "status": 200,
    "body": {
      "id": "chatcmpl-vertex-001",
      "object": "chat.completion",
      "created": 1711000400,
      "model": "gemini-2.0-flash",
      "choices": [
        {
          "index": 0,
          "message": {
            "role": "assistant",
            "content": "Hello!"
          },
          "finish_reason": "stop"
        }
      ],
      "usage": {
        "prompt_tokens": 10,
        "completion_tokens": 3,
        "total_tokens": 13
      }
    }
  },
  "assertions": [
    {
      "type": "not_error"
    },
    {
      "type": "count_equals",
      "field": "choices",
      "value": 1
    },
    {
      "type": "equals",
      "field": "choices[0].message.content",
      "value": "Hello!"
    },
    {
      "type": "equals",
      "field": "choices[0].finish_reason",
      "value": "stop"
    },
    {
      "type": "equals",
      "field": "model",
      "value": "gemini-2.0-flash"
    },
    {
      "type": "equals",
      "field": "usage.total_tokens",
      "value": 13
    }
  ]
}

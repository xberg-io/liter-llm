{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://github.com/kreuzberg-dev/liter-llm/fixtures/schema.json",
	"title": "LiterLM E2E Fixture",
	"description": "Schema for liter-llm end-to-end test fixtures",
	"type": "object",
	"required": ["id", "category", "description", "api", "assertions"],
	"additionalProperties": false,
	"properties": {
		"id": {
			"type": "string",
			"pattern": "^[a-z][a-z0-9_]*$",
			"description": "Unique snake_case identifier used as the test function name"
		},
		"category": {
			"type": "string",
			"enum": [
				"smoke",
				"streaming",
				"error-handling",
				"tool-calling",
				"types",
				"configuration",
				"image-generate",
				"speech",
				"transcribe",
				"moderate",
				"rerank",
				"files",
				"batches",
				"responses",
				"chat",
				"embed",
				"list-models",
				"providers",
				"cache",
				"budget",
				"hooks",
				"custom_provider",
				"parity",
				"search",
				"ocr",
				"contract"
			],
			"description": "Category grouping for the fixture"
		},
		"description": {
			"type": "string",
			"minLength": 5,
			"description": "Human-readable description of what this fixture tests"
		},
		"env": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"api_key_var": {
					"type": "string",
					"description": "Environment variable name holding the API key for live tests"
				}
			},
			"description": "Environment configuration for live/smoke tests against real APIs"
		},
		"api": {
			"type": "object",
			"required": ["method", "request"],
			"additionalProperties": false,
			"properties": {
				"method": {
					"type": "string",
					"enum": [
						"chat",
						"chat_stream",
						"embed",
						"list_models",
						"image_generate",
						"speech",
						"transcribe",
						"moderate",
						"rerank",
						"create_file",
						"retrieve_file",
						"delete_file",
						"list_files",
						"file_content",
						"create_batch",
						"retrieve_batch",
						"list_batches",
						"cancel_batch",
						"create_response",
						"retrieve_response",
						"cancel_response",
						"search",
						"ocr"
					],
					"description": "The API method being tested"
				},
				"request": {
					"type": "object",
					"description": "The request payload to send to the API"
				},
				"mock_response": {
					"type": "object",
					"required": ["status"],
					"additionalProperties": true,
					"properties": {
						"status": {
							"type": "integer",
							"minimum": 100,
							"maximum": 599,
							"description": "HTTP status code to return"
						},
						"body": {
							"type": "object",
							"description": "JSON response body (for non-streaming responses)"
						},
						"stream_chunks": {
							"type": "array",
							"description": "Array of SSE chunk objects for streaming responses",
							"items": {
								"type": "object"
							}
						},
						"stream_terminator": {
							"type": "string",
							"description": "Optional explicit stream terminator, e.g. \"[DONE]\""
						}
					}
				}
			}
		},
		"assertions": {
			"type": "object",
			"description": "Key-value assertions to verify on the response",
			"additionalProperties": true,
			"properties": {
				"status": {
					"type": "string",
					"enum": ["success", "error"],
					"description": "Expected overall response status"
				},
				"response_not_null": {
					"type": "boolean"
				},
				"has_choices": {
					"type": "boolean",
					"description": "Assert response has non-empty choices array"
				},
				"has_usage": {
					"type": "boolean",
					"description": "Assert response includes usage data"
				},
				"has_embeddings": {
					"type": "boolean",
					"description": "Assert response includes embedding data"
				},
				"chunks_received_min": {
					"type": "integer",
					"minimum": 1,
					"description": "Minimum number of streaming chunks expected"
				},
				"both_succeed": {
					"type": "boolean",
					"description": "Assert multiple requests all succeed"
				},
				"choices_count": {
					"type": "integer",
					"minimum": 0
				},
				"first_choice_content": {
					"type": "string"
				},
				"first_choice_finish_reason": {
					"type": "string"
				},
				"usage_total_tokens": {
					"type": "integer",
					"minimum": 0
				},
				"model": {
					"type": "string"
				},
				"embedding_count": {
					"type": "integer",
					"minimum": 1
				},
				"embedding_dimensions": {
					"type": "integer",
					"minimum": 1
				},
				"models_count_min": {
					"type": "integer",
					"minimum": 1
				},
				"stream_chunk_count_min": {
					"type": "integer",
					"minimum": 1
				},
				"stream_final_content": {
					"type": "string"
				},
				"stream_completes_cleanly": {
					"type": "boolean"
				},
				"no_chunks_after_done": {
					"type": "boolean"
				},
				"error_type": {
					"type": "string",
					"enum": ["Authentication", "RateLimited", "ServerError", "NotFound", "InvalidRequest", "Timeout"]
				},
				"error_status_code": {
					"type": "integer",
					"minimum": 400,
					"maximum": 599
				},
				"first_choice_has_tool_calls": {
					"type": "boolean"
				},
				"first_tool_call_function_name": {
					"type": "string"
				},
				"image_count": {
					"type": "integer",
					"minimum": 1
				},
				"image_has_b64_data": {
					"type": "boolean"
				},
				"image_has_url": {
					"type": "boolean"
				},
				"audio_not_empty": {
					"type": "boolean"
				},
				"transcription_text": {
					"type": "string"
				},
				"moderation_result_count": {
					"type": "integer",
					"minimum": 1
				},
				"moderation_has_flagged": {
					"type": "boolean"
				},
				"rerank_result_count": {
					"type": "integer",
					"minimum": 1
				},
				"rerank_has_documents": {
					"type": "boolean"
				},
				"rerank_top_score_min": {
					"type": "number",
					"minimum": 0,
					"maximum": 1
				},
				"file_id": {
					"type": "string"
				},
				"file_count": {
					"type": "integer",
					"minimum": 0
				},
				"file_content_not_empty": {
					"type": "boolean"
				},
				"file_deleted": {
					"type": "boolean"
				},
				"batch_id": {
					"type": "string"
				},
				"batch_status": {
					"type": "string",
					"enum": ["validating", "in_progress", "completed", "failed", "expired", "cancelling", "cancelled"]
				},
				"batch_count": {
					"type": "integer",
					"minimum": 0
				},
				"response_id": {
					"type": "string"
				},
				"response_status": {
					"type": "string",
					"enum": ["completed", "failed", "in_progress", "incomplete", "cancelled"]
				},
				"response_output_count": {
					"type": "integer",
					"minimum": 0
				},
				"response_has_tool_calls": {
					"type": "boolean"
				}
			}
		},
		"tags": {
			"type": "array",
			"items": {
				"type": "string"
			},
			"description": "Optional labels for filtering test runs",
			"default": []
		},
		"skip": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"requires_language": {
					"type": "string",
					"description": "Skip unless the binding under test matches this language"
				},
				"platform": {
					"oneOf": [
						{
							"type": "string"
						},
						{
							"type": "array",
							"items": {
								"type": "string"
							}
						}
					],
					"description": "Skip on these OS platforms (e.g. 'windows' or ['windows', 'linux'])"
				},
				"languages": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Skip for these language bindings (e.g. ['wasm', 'php'])"
				},
				"reason": {
					"type": "string",
					"description": "Human-readable explanation for why the test is skipped"
				}
			},
			"description": "Conditions under which the test should be skipped"
		}
	}
}

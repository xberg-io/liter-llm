{
  "id": "smoke_response_with_tools",
  "description": "Response that includes tool call output items",
  "category": "responses",
  "tags": ["smoke", "responses"],
  "call": "create_response",
  "input": {
    "model": "gpt-4o",
    "input": "What is the weather in San Francisco?",
    "tools": [
      {
        "type": "function",
        "name": "get_weather",
        "description": "Get current weather for a location",
        "parameters": {
          "type": "object",
          "properties": {
            "location": {
              "type": "string"
            }
          },
          "required": ["location"]
        }
      }
    ]
  },
  "mock_response": {
    "status": 200,
    "body": {
      "id": "resp-tool001",
      "object": "response",
      "created_at": 1711000000,
      "status": "completed",
      "model": "gpt-4o",
      "output": [
        {
          "type": "function_call",
          "id": "fc-001",
          "call_id": "call-001",
          "name": "get_weather",
          "arguments": "{\"location\": \"San Francisco\"}"
        },
        {
          "type": "message",
          "id": "msg-002",
          "role": "assistant",
          "content": [
            {
              "type": "output_text",
              "text": "The weather in San Francisco is currently 65F and sunny."
            }
          ]
        }
      ],
      "usage": {
        "input_tokens": 50,
        "output_tokens": 35,
        "total_tokens": 85
      }
    }
  },
  "assertions": [
    {
      "type": "not_error"
    },
    {
      "type": "not_empty",
      "field": "id"
    },
    {
      "type": "equals",
      "field": "status",
      "value": "completed"
    },
    {
      "type": "count_equals",
      "field": "output",
      "value": 2
    },
    {
      "type": "not_empty",
      "field": "output"
    }
  ]
}

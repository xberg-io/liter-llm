{
  "id": "error_response_auth_401",
  "description": "401 Unauthorized when creating a response with invalid API key",
  "category": "responses",
  "tags": ["error-handling", "responses"],
  "call": "create_response",
  "input": {
    "model": "gpt-4o",
    "input": "Hello"
  },
  "mock_response": {
    "status": 401,
    "body": {
      "error": {
        "message": "Incorrect API key provided.",
        "type": "invalid_request_error",
        "param": null,
        "code": "invalid_api_key"
      }
    }
  },
  "assertions": [
    {
      "type": "error",
      "value": "Authentication"
    },
    {
      "type": "equals",
      "field": "error.status_code",
      "value": 401
    }
  ]
}

{
  "id": "error_response_not_found",
  "description": "404 Not Found when retrieving a nonexistent response",
  "category": "responses",
  "tags": ["error-handling", "responses"],
  "call": "retrieve_response",
  "input": {
    "response_id": "resp-nonexistent"
  },
  "mock_response": {
    "status": 404,
    "body": {
      "error": {
        "message": "No such Response object: resp-nonexistent",
        "type": "invalid_request_error",
        "param": null,
        "code": null
      }
    }
  },
  "assertions": [
    {
      "type": "error",
      "value": "NotFound"
    },
    {
      "type": "equals",
      "field": "error.status_code",
      "value": 404
    }
  ]
}

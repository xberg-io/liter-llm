{
  "id": "error_batch_not_found",
  "description": "404 Not Found when retrieving a nonexistent batch",
  "category": "batches",
  "tags": ["error-handling", "batches"],
  "call": "retrieve_batch",
  "input": {
    "batch_id": "batch-nonexistent"
  },
  "mock_response": {
    "status": 404,
    "body": {
      "error": {
        "message": "No such Batch object: batch-nonexistent",
        "type": "invalid_request_error",
        "param": null,
        "code": null
      }
    }
  },
  "assertions": [
    {
      "type": "error",
      "value": "NotFound"
    },
    {
      "type": "equals",
      "field": "error.status_code",
      "value": 404
    }
  ]
}

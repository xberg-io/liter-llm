{
  "id": "error_batch_invalid_file",
  "description": "400 Bad Request when creating a batch with invalid input file",
  "category": "batches",
  "tags": ["error-handling", "batches"],
  "call": "create_batch",
  "input": {
    "input_file_id": "file-wrong-purpose",
    "endpoint": "/v1/chat/completions",
    "completion_window": "24h"
  },
  "mock_response": {
    "status": 400,
    "body": {
      "error": {
        "message": "The file 'file-wrong-purpose' has purpose 'fine-tune', but batch requires 'batch'.",
        "type": "invalid_request_error",
        "param": "input_file_id",
        "code": null
      }
    }
  },
  "assertions": [
    {
      "type": "error",
      "value": "BadRequest"
    },
    {
      "type": "equals",
      "field": "error.status_code",
      "value": 400
    }
  ]
}

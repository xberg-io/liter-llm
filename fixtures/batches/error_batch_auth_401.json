{
  "id": "error_batch_auth_401",
  "description": "401 Unauthorized when creating a batch with invalid API key",
  "category": "batches",
  "tags": ["error-handling", "batches"],
  "call": "create_batch",
  "input": {
    "input_file_id": "file-abc123",
    "endpoint": "/v1/chat/completions",
    "completion_window": "24h"
  },
  "mock_response": {
    "status": 401,
    "body": {
      "error": {
        "message": "Incorrect API key provided.",
        "type": "invalid_request_error",
        "param": null,
        "code": "invalid_api_key"
      }
    }
  },
  "assertions": [
    {
      "type": "error",
      "value": "Authentication"
    },
    {
      "type": "equals",
      "field": "error.status_code",
      "value": 401
    }
  ]
}

{
  "id": "server_error_500",
  "description": "500 Internal Server Error from the upstream API",
  "category": "error-handling",
  "tags": ["error-handling"],
  "call": "chat",
  "input": {
    "model": "gpt-4",
    "messages": [
      {
        "role": "user",
        "content": "Hello"
      }
    ]
  },
  "mock_response": {
    "status": 500,
    "body": {
      "error": {
        "message": "The server had an error while processing your request. Sorry about that!",
        "type": "server_error",
        "param": null,
        "code": null
      }
    }
  },
  "assertions": [
    {
      "type": "error",
      "value": "ServerError"
    },
    {
      "type": "equals",
      "field": "error.status_code",
      "value": 500
    }
  ]
}

{
  "id": "service_unavailable_502",
  "description": "502 Bad Gateway error when the upstream service is unavailable",
  "category": "error-handling",
  "tags": ["error-handling"],
  "call": "chat",
  "input": {
    "model": "gpt-4",
    "messages": [
      {
        "role": "user",
        "content": "Hello"
      }
    ]
  },
  "mock_response": {
    "status": 502,
    "body": {
      "error": {
        "message": "Bad gateway",
        "type": "server_error"
      }
    }
  },
  "assertions": [
    {
      "type": "error",
      "value": "ServiceUnavailable"
    },
    {
      "type": "equals",
      "field": "error.status_code",
      "value": 502
    }
  ]
}

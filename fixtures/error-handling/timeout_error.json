{
  "id": "timeout_error",
  "description": "408 Request Timeout error when the API request takes too long to complete",
  "category": "error-handling",
  "tags": ["error-handling"],
  "call": "chat",
  "input": {
    "model": "gpt-4",
    "messages": [
      {
        "role": "user",
        "content": "Hello"
      }
    ]
  },
  "mock_response": {
    "status": 408,
    "body": {
      "error": {
        "message": "Request timeout",
        "type": "timeout_error",
        "code": "timeout"
      }
    }
  },
  "assertions": [
    {
      "type": "error",
      "value": "Timeout"
    },
    {
      "type": "equals",
      "field": "error.status_code",
      "value": 408
    }
  ]
}

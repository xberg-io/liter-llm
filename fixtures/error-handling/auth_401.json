{
  "id": "auth_401",
  "description": "401 Unauthorized error when API key is invalid or missing",
  "category": "error-handling",
  "tags": ["error-handling"],
  "call": "chat",
  "input": {
    "model": "gpt-4",
    "messages": [
      {
        "role": "user",
        "content": "Hello"
      }
    ]
  },
  "mock_response": {
    "status": 401,
    "body": {
      "error": {
        "message": "Incorrect API key provided. You can find your API key at https://platform.openai.com/account/api-keys.",
        "type": "invalid_request_error",
        "param": null,
        "code": "invalid_api_key"
      }
    }
  },
  "assertions": [
    {
      "type": "error",
      "value": "Authentication"
    },
    {
      "type": "equals",
      "field": "error.status_code",
      "value": 401
    }
  ]
}

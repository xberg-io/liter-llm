{
  "id": "rate_limit_429",
  "description": "429 Too Many Requests error when the rate limit is exceeded",
  "category": "error-handling",
  "tags": ["error-handling"],
  "call": "chat",
  "input": {
    "model": "gpt-4",
    "messages": [
      {
        "role": "user",
        "content": "Hello"
      }
    ]
  },
  "mock_response": {
    "status": 429,
    "body": {
      "error": {
        "message": "Rate limit reached for gpt-4 in organization org-abc123 on tokens per min. Limit: 10000, Used: 10000, Requested: 100. Please try again in 600ms.",
        "type": "requests",
        "param": null,
        "code": "rate_limit_exceeded"
      }
    }
  },
  "assertions": [
    {
      "type": "error",
      "value": "RateLimited"
    },
    {
      "type": "equals",
      "field": "error.status_code",
      "value": 429
    }
  ]
}

{
  "id": "not_found_404",
  "description": "404 Not Found error when requesting a model that does not exist",
  "category": "error-handling",
  "tags": ["error-handling"],
  "call": "chat",
  "input": {
    "model": "gpt-99",
    "messages": [
      {
        "role": "user",
        "content": "Hello"
      }
    ]
  },
  "mock_response": {
    "status": 404,
    "body": {
      "error": {
        "message": "Model not found",
        "type": "not_found_error"
      }
    }
  },
  "assertions": [
    {
      "type": "error",
      "value": "NotFound"
    },
    {
      "type": "equals",
      "field": "error.status_code",
      "value": 404
    }
  ]
}

{
  "id": "forbidden_403",
  "description": "403 Forbidden error when the API key does not have access to the requested resource",
  "category": "error-handling",
  "tags": ["error-handling"],
  "call": "chat",
  "input": {
    "model": "gpt-4",
    "messages": [
      {
        "role": "user",
        "content": "Hello"
      }
    ]
  },
  "mock_response": {
    "status": 403,
    "body": {
      "error": {
        "message": "Access denied",
        "type": "access_denied"
      }
    }
  },
  "assertions": [
    {
      "type": "error",
      "value": "Authentication"
    },
    {
      "type": "equals",
      "field": "error.status_code",
      "value": 403
    }
  ]
}

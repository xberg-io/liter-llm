{
  "id": "hook_on_error",
  "description": "Tests that on_error hook is called on failure",
  "category": "hooks",
  "tags": ["hooks"],
  "skip": {
    "languages": []
  },
  "call": "chat",
  "input": {
    "model": "gpt-4",
    "messages": [
      {
        "role": "user",
        "content": "Hello"
      }
    ]
  },
  "mock_response": {
    "status": 500,
    "body": {
      "error": {
        "message": "Internal server error",
        "type": "server_error",
        "code": "internal_error"
      }
    }
  },
  "assertions": [
    {
      "type": "is_true",
      "field": "hook_on_error_called"
    }
  ]
}

{
  "id": "hook_on_response",
  "description": "Tests that on_response hook is called with response data",
  "category": "hooks",
  "tags": ["hooks"],
  "skip": {
    "languages": []
  },
  "call": "chat",
  "input": {
    "model": "gpt-4",
    "messages": [
      {
        "role": "user",
        "content": "Hello"
      }
    ]
  },
  "mock_response": {
    "status": 200,
    "body": {
      "id": "chatcmpl-hook-resp-001",
      "object": "chat.completion",
      "created": 1711000000,
      "model": "gpt-4",
      "choices": [
        {
          "index": 0,
          "message": {
            "role": "assistant",
            "content": "Hello! How can I help you today?"
          },
          "finish_reason": "stop"
        }
      ],
      "usage": {
        "prompt_tokens": 8,
        "completion_tokens": 9,
        "total_tokens": 17
      }
    }
  },
  "assertions": [
    {
      "type": "not_error"
    },
    {
      "type": "is_true",
      "field": "hook_on_response_called"
    }
  ]
}

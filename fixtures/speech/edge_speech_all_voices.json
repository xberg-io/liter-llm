{
  "id": "edge_speech_all_voices",
  "description": "Text-to-speech with specific voice selection",
  "category": "speech",
  "tags": ["speech", "edge-case"],
  "call": "speech",
  "input": {
    "model": "tts-1",
    "input": "Hello world",
    "voice": "nova"

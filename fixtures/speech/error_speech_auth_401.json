{
  "id": "error_speech_auth_401",
  "description": "401 Unauthorized for speech generation with invalid API key",
  "category": "speech",
  "tags": ["error-handling", "speech"],
  "call": "speech",
  "input": {
    "model": "tts-1",
    "input": "Hello",
    "voice": "alloy"
  },
  "mock_response": {
    "status": 401,
    "body": {
      "error": {
        "message": "Incorrect API key provided.",
        "type": "invalid_request_error",
        "param": null,
        "code": "invalid_api_key"
      }
    }
  },
  "assertions": [
    {
      "type": "error",
      "value": "Authentication"
    },
    {
      "type": "equals",
      "field": "error.status_code",
      "value": 401
    }
  ]
}

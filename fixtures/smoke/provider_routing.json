{
  "id": "smoke_provider_routing",
  "description": "Test provider routing by sending requests to OpenAI and Anthropic",
  "category": "smoke",
  "tags": ["smoke", "openai", "anthropic", "routing"],
  "call": "chat",
  "input": {
    "model": "openai/gpt-4o-mini",
    "messages": [
      {
        "role": "user",
        "content": "Say hi."
      }
    ],
    "max_tokens": 5
  },
  "env": {
    "api_key_var": "OPENAI_API_KEY"
  },
  "mock_response": {
    "status": 200,
    "body": {
      "id": "chatcmpl-smoke005",
      "object": "chat.completion",
      "created": 1711000000,
      "model": "gpt-4o-mini",
      "choices": [
        {
          "index": 0,
          "message": {
            "role": "assistant",
            "content": "Hi"
          },
          "finish_reason": "stop"
        }
      ],
      "usage": {
        "prompt_tokens": 8,
        "completion_tokens": 1,
        "total_tokens": 9
      }
    }
  },
  "assertions": [
    {
      "type": "not_error"
    },
    {
      "type": "not_error"
    },
    {
      "type": "not_empty",
      "field": "choices"
    },
    {
      "type": "not_error"
    }
  ],
  "skip": {
    "languages": ["rust"],
    "reason": "requires live API credentials not available in mock-based test environment"
  }
}

		"body": {
			"id": "chatcmpl-smoke004",
			"object": "chat.completion",
			"created": 1711000000,
			"model": "gpt-4o-mini",
			"choices": [
				{
					"index": 0,
					"message": {
						"role": "assistant",
						"content": "4"
					},
					"finish_reason": "stop"
				}
			],
			"usage": {
				"prompt_tokens": 16,
				"completion_tokens": 1,
				"total_tokens": 17
			}
		}

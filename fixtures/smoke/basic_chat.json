{
  "id": "basic_chat",
  "description": "Basic chat completion with a single user message",
  "category": "smoke",
  "tags": ["smoke"],
  "call": "chat",
  "input": {
    "model": "gpt-4",
    "messages": [
      {
        "role": "user",
        "content": "Say hello"
      }
    ],
    "temperature": 0
  },
  "mock_response": {
    "status": 200,
    "body": {
      "id": "chatcmpl-abc123",
      "object": "chat.completion",
      "created": 1711000000,
      "model": "gpt-4",
      "choices": [
        {
          "index": 0,
          "message": {
            "role": "assistant",
            "content": "Hello!"
          },
          "finish_reason": "stop"
        }
      ],
      "usage": {
        "prompt_tokens": 10,
        "completion_tokens": 5,
        "total_tokens": 15
      }
    }
  },
  "assertions": [
    {
      "type": "not_error"
    },
    {
      "type": "count_equals",
      "field": "choices",
      "value": 1
    },
    {
      "type": "equals",
      "field": "choices[0].message.content",
      "value": "Hello!"
    },
    {
      "type": "equals",
      "field": "choices[0].finish_reason",
      "value": "stop"
    },
    {
      "type": "equals",
      "field": "usage.total_tokens",
      "value": 15
    },
    {
      "type": "equals",
      "field": "model",
      "value": "gpt-4"
    }
  ]
}

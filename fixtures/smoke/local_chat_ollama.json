{
	"id": "local_chat_ollama",
	"description": "Chat completion against local Ollama with qwen2:0.5b model",
	"category": "smoke",
	"tags": ["smoke", "local", "ollama"],
	"call": "chat",
	"input": {
		"model": "ollama/qwen2:0.5b",
		"messages": [
			{
				"role": "user",
				"content": "Say hello in one word."
			}
		],
		"max_tokens": 10
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "not_error"
		},
		{
			"type": "not_empty",
			"field": "choices"
		}
	],
	"skip": {
		"languages": [
			"rust",
			"python",
			"node",
			"ruby",
			"php",
			"go",
			"java",
			"csharp",
			"elixir",
			"wasm",
			"c",
			"kotlin",
			"kotlin_android",
			"swift",
			"dart",
			"zig"
		],
		"reason": "requires local Ollama service; skipped in standard CI environments"
	}
}

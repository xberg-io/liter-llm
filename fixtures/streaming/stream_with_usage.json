{
  "id": "stream_with_usage",
  "description": "Streaming chat completion that includes a usage summary in the final chunk",
  "category": "streaming",
  "tags": [
    "streaming"
  ],
  "call": "chat_stream",
  "skip": {
    "languages": [
      "rust",
      "python",
      "node",
      "ruby",
      "php",
      "go",
      "java",
      "csharp",
      "elixir",
      "wasm",
      "c"
    ],
    "reason": "Rust returns BoxStream \u2014 collecting usage from the final chunk requires consuming the stream, which is not supported by the generator; Python ChatStreamIterator does not expose a .usage attribute"
  },
  "input": {
    "model": "gpt-4",
    "messages": [
      {
        "role": "user",
        "content": "Say hi"
      }
    ],
    "stream": true,
    "stream_options": {
      "include_usage": true
    }
  },
  "mock_response": {
    "status": 200,
    "stream_chunks": [

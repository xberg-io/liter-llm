{
  "id": "stream_error_401",
  "description": "401 Unauthorized error on stream initiation before any chunks are received",
  "category": "streaming",
  "tags": ["streaming", "error-handling"],
  "call": "chat_stream",
  "input": {
    "model": "gpt-4",
    "messages": [
      {
        "role": "user",
        "content": "Hello"
      }
    ],
    "stream": true
  },
  "mock_response": {
    "status": 401,
    "body": {
      "error": {
        "message": "Incorrect API key provided.",
        "type": "invalid_request_error",
        "param": null,
        "code": "invalid_api_key"
      }
    }
  },
  "assertions": [
    {
      "type": "error",
      "value": "Authentication"
    },
    {
      "type": "equals",
      "field": "error.status_code",
      "value": 401
    }
  ]
}

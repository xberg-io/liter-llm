{
  "id": "empty_stream",
  "description": "Streaming chat completion that produces no content chunks before the DONE signal",
  "category": "streaming",
  "tags": ["streaming", "edge-case"],
  "call": "chat_stream",
  "input": {
    "model": "gpt-4",
    "messages": [
      {
        "role": "user",
        "content": "Say nothing"
      }
    ],
    "stream": true
  },
  "mock_response": {
    "status": 200,
    "stream_chunks": []
  },
  "assertions": [
    {
      "type": "count_min",
      "field": "chunks",
      "value": 0
    },
    {
      "type": "equals",
      "field": "stream_content",
      "value": ""
    }
  ]
}

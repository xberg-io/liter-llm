{
  "id": "custom_base_url",
  "description": "Client configured with a custom base URL routes all requests to that endpoint",
  "category": "configuration",
  "tags": ["configuration"],
  "call": "chat",
  "input": {
    "model": "local-model",
    "messages": [
      {
        "role": "user",
        "content": "Hello"
      }
    ]
  },
  "mock_response": {
    "status": 200,
    "body": {
      "id": "chatcmpl-local-001",
      "object": "chat.completion",
      "created": 1711000000,
      "model": "local-model",
      "choices": [
        {
          "index": 0,
          "message": {
            "role": "assistant",
            "content": "Hi there!"
          },
          "finish_reason": "stop"
        }
      ],
      "usage": {
        "prompt_tokens": 3,
        "completion_tokens": 4,
        "total_tokens": 7
      }
    }
  },
  "assertions": [
    {
      "type": "not_error"
    },
    {
      "type": "count_equals",
      "field": "choices",
      "value": 1
    },
    {
      "type": "equals",
      "field": "choices[0].message.content",
      "value": "Hi there!"
    },
    {
      "type": "equals",
      "field": "choices[0].finish_reason",
      "value": "stop"
    },
    {
      "type": "equals",
      "field": "model",
      "value": "local-model"
    }
  ]
}

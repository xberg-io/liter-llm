{
  "id": "edge_rerank_single_doc",
  "description": "Reranking with only a single document",
  "category": "rerank",
  "tags": ["edge-case", "rerank"],
  "call": "rerank",
  "input": {
    "model": "rerank-v3.5",
    "query": "What is AI?",
    "documents": ["Artificial intelligence is the simulation of human intelligence."]
  },
  "mock_response": {
    "status": 200,
    "body": {
      "id": "rerank-single001",
      "results": [
        {
          "index": 0,
          "relevance_score": 0.98
        }
      ],
      "meta": {
        "api_version": {
          "version": "2"
        },
        "billed_units": {
          "search_units": 1
        }
      }
    }
  },
  "assertions": [
    {
      "type": "not_error"
    },
    {
      "type": "count_equals",
      "field": "results",
      "value": 1
    },
    {
      "type": "greater_than",
      "field": "results[0].relevance_score",
      "value": 0.9
    }
  ]
}

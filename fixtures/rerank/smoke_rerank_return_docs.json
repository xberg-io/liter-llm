{
  "id": "smoke_rerank_return_docs",
  "description": "Reranking with return_documents flag to include document text",
  "category": "rerank",
  "tags": ["smoke", "rerank"],
  "call": "rerank",
  "input": {
    "model": "rerank-v3.5",
    "query": "What is Rust?",
    "documents": ["Rust is a systems programming language.", "Iron rusts when exposed to water."],
    "return_documents": true
  },
  "mock_response": {
    "status": 200,
    "body": {
      "id": "rerank-ghi789",
      "results": [
        {
          "index": 0,
          "relevance_score": 0.96,
          "document": {
            "text": "Rust is a systems programming language."
          }
        },
        {
          "index": 1,
          "relevance_score": 0.12,
          "document": {
            "text": "Iron rusts when exposed to water."
          }
        }
      ],
      "meta": {
        "api_version": {
          "version": "2"
        },
        "billed_units": {
          "search_units": 1
        }
      }
    }
  },
  "assertions": [
    {
      "type": "not_error"
    },
    {
      "type": "count_equals",
      "field": "results",
      "value": 2
    },
    {
      "type": "not_empty",
      "field": "results[0].document"
    },
    {
      "type": "greater_than",
      "field": "results[0].relevance_score",
      "value": 0.9
    }
  ]
}

{
  "id": "embed_encoding_format",
  "description": "Embedding request with explicit encoding_format of float returns float array embeddings",
  "category": "embed",
  "tags": ["embed"],
  "call": "embed",
  "input": {
    "model": "text-embedding-3-small",
    "input": "Test input",
    "encoding_format": "float"
  },
  "mock_response": {
    "status": 200,
    "body": {
      "object": "list",
      "model": "text-embedding-3-small",
      "data": [
        {
          "object": "embedding",
          "index": 0,
          "embedding": [0.123, 0.456, 0.789, 0.012, 0.345]
        }
      ],
      "usage": {
        "prompt_tokens": 2,
        "completion_tokens": 0,
        "total_tokens": 2
      }
    }
  },
  "assertions": [
    {
      "type": "not_error"
    },
    {
      "type": "count_equals",
      "field": "data",
      "value": 1
    },
    {
      "type": "count_equals",
      "field": "data[0].embedding",
      "value": 5
    }
  ]
}

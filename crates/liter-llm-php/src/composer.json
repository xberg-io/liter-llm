{
  "name": "xberg-io/liter-llm",
  "description": "Universal LLM API client with Rust-powered polyglot bindings.",
  "license": "MIT",
  "type": "php-ext",
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1"
  },
  "autoload": {
    "psr-4": {
      "Liter\\Llm\\": "src/"
    }
  },
  "scripts": {
    "format": "poly fmt --fix",
    "format:check": "poly fmt --check",
    "test": "php vendor/bin/phpunit",
    "lint": "poly lint",
    "lint:fix": "poly lint --fix && poly fmt --fix"
  },
  "php-ext": {
    "extension-name": "liter_llm",
    "support-zts": true,
    "support-nts": true,
    "download-url-method": "pre-packaged-binary"
  },
  "keywords": ["anthropic", "api-client", "llm", "openai"],
  "extra": {
    "pie": {
      "binary": {
        "url-template": "https://github.com/xberg-io/liter-llm/releases/download/{Version}/php_liter_llm-{Version}_php{PhpVersion}-{Arch}-{OSLower}-{Libc}-{TSMode}.tgz"
      }
    }
  }
}

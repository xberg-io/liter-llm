# Go
# packages/go/include/liter_llm.h and packages/go/.lib/<platform>/ are tracked:
# they ship in the Go module git tag so `go get + build` is self-contained.
# publish-go-module CI job populates .lib/ before creating the packages/go/{tag}.
# The legacy packages/go/lib/ path (no leading dot) remains ignored.
packages/go/lib/
# Unignore the prebuilt shared libs under packages/go/.lib/<platform>/ that the
# publish workflow bundles into the Go module tag (root *.so/*.dylib/*.dll
# rules above otherwise hide them from `git add`).
!packages/go/.lib/**/*.so
!packages/go/.lib/**/*.dylib
!packages/go/.lib/**/*.dll
coverage.out

